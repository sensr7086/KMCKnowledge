## 변수 치환 절차 (인스턴스화 시)

새 프로젝트에 plugin 의 templates/ 를 적용할 때, **본 파일을 *제외한* 나머지 .template 파일들에서** 위 값으로 placeholder 치환:

```bash
# Linux/WSL/bash
KNOWLEDGE_REPO=/path/to/new/repo
mkdir -p "$KNOWLEDGE_REPO/catalogs" "$KNOWLEDGE_REPO/entities"

mkdir -p "$KNOWLEDGE_REPO/ue-cross-cutting-policies"
for f in CLAUDE.md STRUCTURE.md categories.md index.md ue-cross-cutting-policies/index.md; do
  sed -e "s|{{ PROJECT_NAME }}|MyProject|g" \
      -e "s|{{ KNOWLEDGE_REPO_NAME }}|MyProjectKnowledge|g" \
      -e "s|{{ KNOWLEDGE_REPO_PATH }}|E:\\\\MyProject\\\\MyProjectKnowledge|g" \
      -e "s|{{ CODE_REPO_PATH }}|E:\\\\MyProject\\\\MyProject|g" \
      -e "s|{{ ENTITY_NAME_PREFIX }}|MP|g" \
      -e "s|{{ MODULE_API_PREFIXES }}|MYPROJECTMODULE|g" \
      -e "s|{{ UE_VERSION }}|5.7.4|g" \
      -e "s|{{ MCWIKI_MCP_SERVER_NAME }}|MCWiki_-_UE_5_7_4_Knowledge_Vault|g" \
      < templates/${f}.template > "$KNOWLEDGE_REPO/$f"
done
```

PowerShell 동등:
```powershell
$Vars = @{
    PROJECT_NAME = "MyProject"
    KNOWLEDGE_REPO_NAME = "MyProjectKnowledge"
    KNOWLEDGE_REPO_PATH = "E:\MyProject\MyProjectKnowledge"
    CODE_REPO_PATH = "E:\MyProject\MyProject"
    ENTITY_NAME_PREFIX = "MP"
    MODULE_API_PREFIXES = "MYPROJECTMODULE"
    UE_VERSION = "5.7.4"
    MCWIKI_MCP_SERVER_NAME = "MCWiki_-_UE_5_7_4_Knowledge_Vault"
}
New-Item -ItemType Directory -Force "$KnowledgeRepo/ue-cross-cutting-policies" | Out-Null
foreach ($f in 'CLAUDE.md','STRUCTURE.md','categories.md','index.md','ue-cross-cutting-policies/index.md') {
    $content = Get-Content "templates/${f}.template" -Raw
    foreach ($k in $Vars.Keys) {
        $content = $content -replace "\{\{ $k \}\}", $Vars[$k]
    }
    Set-Content "$KnowledgeRepo/$f" $content
}
```

